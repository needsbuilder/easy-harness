{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Easy Harness",
  "version": "0.1.1",
  "identifier": "ai.needslab.easyharness",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "이지 하네스",
        "width": 1100,
        "height": 720,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "recipes"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJBNkQxNDE2NThBQjJFM0EKUldRNkxxdFlGaFJ0S2lxY2IzQ2lkdjNldlB5WnFENzh4eUdCRm0yejUyUTlRV3JWSVBTb0c4aE8K",
      "endpoints": [
        "https://github.com/needslab-ai/easy-harness-releases/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}

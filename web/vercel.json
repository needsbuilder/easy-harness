{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "easyharness\\.vercel\\.app" }],
      "destination": "https://easyharness.needslab.ai/",
      "permanent": true
    },
    {
      "source": "/:path+",
      "has": [{ "type": "host", "value": "easyharness\\.vercel\\.app" }],
      "destination": "https://easyharness.needslab.ai/:path+",
      "permanent": true
    }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
